# ─── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info
RELOAD=false
APP_VERSION=1.0.0

# ─── Timeouts ─────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=90

# ─── OCR Engine ───────────────────────────────────────────────────────────────
# MAX_DIM: max image dimension fed to OCR (lower = faster, 1000 is the code default)
# MIN_DIM: below this, image is upscaled before OCR
OCR_MAX_DIM=1000
OCR_MIN_DIM=600

# ─── Paths ────────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
